{
  "argv": [
    "/opt/conda/bin/python",
    "-m",
    "ipykernel_launcher",
    "-f",
    "{connection_file}"
  ],
  "env": {
    "PYSPARK_PYTHON": "/opt/conda/bin/python",
    "PYSPARK_DRIVER_PYTHON": "/opt/conda/bin/python",
    "PYTHONPATH": "/usr/local/spark/python:/opt/conda/lib/python3.11/site-packages"
  },
  "display_name": "Spark",
  "language": "python",
  "interrupt_mode": "signal",
  "metadata": {
    "debugger": true
  }
}
